rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is an authenticated admin
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in get(/databases/$(database)/documents/config/admins).data.emails;
    }

    // Helper: Check if the referenced event has voting open
    function isVotingOpen(eventId) {
      let event = get(/databases/$(database)/documents/events/$(eventId));
      return event.data.status == 'open';
    }

    // Config collection - public read for admin whitelist check before auth
    match /config/{document} {
      allow read: if true;
      allow write: if false; // Manage via Firebase Console only
    }

    // Events collection
    match /events/{eventId} {
      // Anyone can read events (to check if voting is open)
      allow read: if true;
      // Only admins can create/update/delete events
      allow write: if isAdmin();
    }

    // Ballots collection
    match /ballots/{ballotCode} {
      // Anyone can read a ballot if they know the code
      allow read: if true;

      // Only admins can create or delete ballots
      allow create: if isAdmin();
      allow delete: if isAdmin();

      // Update rules for voting
      allow update: if
        // Admin can do anything
        isAdmin() ||
        // Or: ballot exists, not yet submitted, and voting is open
        (
          resource.data.submitted == false &&
          isVotingOpen(resource.data.eventId) &&
          // Cannot change immutable fields
          request.resource.data.eventId == resource.data.eventId &&
          request.resource.data.type == resource.data.type &&
          request.resource.data.createdAt == resource.data.createdAt &&
          // Cannot un-submit once submitted
          (resource.data.submitted == false || request.resource.data.submitted == true)
        );
    }
  }
}
